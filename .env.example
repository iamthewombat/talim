# --- Bridge auth (required) ---
TALIM_BRIDGE_SECRET=change-me-to-a-long-random-string
# Browser dashboard session duration after entering the bridge secret once.
TALIM_DASHBOARD_SESSION_DAYS=90

# --- LLM ---
ANTHROPIC_API_KEY=
# `host.docker.internal` resolves on Docker Desktop (Mac/Windows). On Linux
# hosts (e.g. a VPS) use `http://<host-gateway>:11434` (often
# `172.17.0.1`), or run Ollama with `--network host`. Leave blank to skip.
OLLAMA_URL=http://host.docker.internal:11434

# --- Discord (optional — leave blank to run headless) ---
TALIM_DISCORD_TOKEN=
TALIM_DISCORD_ALERTS_CHANNEL=
TALIM_DISCORD_CHAT_CHANNEL=
TALIM_DISCORD_LOG_CHANNEL=
# Discord webhook URL for immediate close-out notifications (create in
# channel settings → Integrations → Webhooks). Leave blank to disable.
TALIM_DISCORD_CLOSEOUT_WEBHOOK=

# --- Exchange selection ---
# Default is MockExchange. Broker keys below are ignored unless this is changed.
TALIM_EXCHANGE_MODE=mock
TALIM_EXCHANGE_NAME=
TALIM_INSTRUMENTS=
TALIM_STRATEGIES=
TALIM_DEFAULT_QTY=1
TALIM_BAR_WINDOW=50
TALIM_CHECKPOINT_DB=state/talim_checkpoints.db
TALIM_EPISODIC_DB=state/episodic.db
TALIM_BACKTEST_HISTORY_DB=state/backtest_history.db
TALIM_RISK_CONFIG=config/risk.json

# --- Persistence layout (WP-47) ---
# Both the Talim and scheduler containers bind-mount these host directories
# at /app/state and /app/backups respectively. Override only if you want to
# point them somewhere else inside the container — change the bind-mount in
# docker-compose.yml in lockstep. See docs/vps-migration.md.
TALIM_STATE_DIR=/app/state
TALIM_BACKUP_DIR=/app/backups

# --- Binance / ccxt exchange creds (optional) ---
# Used only when TALIM_EXCHANGE_MODE=testnet|live and TALIM_EXCHANGE_NAME=binance.
# Not used by the IG/FOREX.com CFD path.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Price feed (optional) ---
# TALIM_PRICEFEED=binance uses the public ccxt.pro feed scaffold and does not
# consume BINANCE_API_KEY / BINANCE_API_SECRET.
TALIM_PRICEFEED=mock
TALIM_PRICEFEED_TIMEFRAME=5m
# Mock-only: load deterministic bars at startup so HTTP operator HITL can be validated.
TALIM_MOCK_DEMO_DATA=
TALIM_MOCK_FILL_PRICE=5000

# --- IG CFD adapter (optional) ---
IG_API_KEY=
IG_IDENTIFIER=
IG_PASSWORD=
IG_CST=
IG_SECURITY_TOKEN=
IG_ENVIRONMENT=demo

# --- FOREX.com CFD adapter (optional) ---
FOREXDOTCOM_LOGIN=
FOREXDOTCOM_PASSWORD=
FOREXDOTCOM_APP_KEY=
FOREXDOTCOM_ENVIRONMENT=demo
FOREXDOTCOM_TRADING_ACCOUNT_ID=
FOREXDOTCOM_CLIENT_ACCOUNT_ID=

# --- CFD registry (optional override) ---
TALIM_CFD_REGISTRY_PATH=config/cfd_instruments.json

# Public URL used in operator signal/dashboard deep links.
TALIM_PUBLIC_BASE_URL=http://127.0.0.1:8080/talim
