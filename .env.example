# --- Bridge auth (required) ---
TALIM_BRIDGE_SECRET=change-me-to-a-long-random-string

# --- LLM ---
ANTHROPIC_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434

# --- Discord (optional — leave blank to run headless) ---
TALIM_DISCORD_TOKEN=
TALIM_DISCORD_ALERTS_CHANNEL=
TALIM_DISCORD_CHAT_CHANNEL=
TALIM_DISCORD_LOG_CHANNEL=

# --- Exchange creds (optional — MockExchange used by default) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
