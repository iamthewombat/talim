# Virtual environments
.venv/
venv/
__pycache__/
*.pyc
*.pyo

# Secrets
.env
.env.backup*
.env.bak*

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code
.claude/

# Data (directory committed via .gitkeep like the WP-47 state dirs;
# contents are local datasets)
/data/*
!/data/.gitkeep
*.parquet

# SQLite
*.db
*.db-journal

# OS
.DS_Store
Thumbs.db

# Docker volumes
nginx/certs/

# Bind-mounted runtime state (WP-47). Directories are committed via
# .gitkeep; their contents are local to each host.
/state/*
!/state/.gitkeep
/redis/*
!/redis/.gitkeep
/backups/*
!/backups/.gitkeep

# Distribution
dist/
*.egg-info/
build/

# Local runtime logs (Dukascopy pulls, ad-hoc script runs)
logs/
